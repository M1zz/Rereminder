      }
    },
    "onboarding_desc_2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Avoid awkward moments from going overtime and keep your audience comfortable"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "시간 초과로 인한 당황스러운 상황, 청중의 불편함을 방지하세요"
          }
        }
      }
    },
    "onboarding_desc_3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Set as many pre-alerts as you want: 10 min, 5 min, 1 min before the end"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "종료 10분 전, 5분 전, 1분 전 등 원하는 만큼 예비 알림을 설정하세요"
          }
        }
      }
    },
    "onboarding_desc_4": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "After 00:00, it shows +01:23 so you know exactly how much overtime"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "00:00 이후에도 +01:23처럼 표시되어 정확히 얼마나 초과했는지 확인하세요"
          }
        }
      }
    },
    "onboarding_desc_5": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "• Intuitive circular drag\n• Precise number input\n• Quick presets for instant start"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "• 원형 드래그로 직관적 설정\n• 숫자 입력으로 정확한 시간\n• 빠른 프리셋으로 즉시 시작"
          }
        }
      }
    },
