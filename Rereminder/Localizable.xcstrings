    "On" : {

    },
    "onboarding_desc_1" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Keeping precise time during lectures, mentoring, and meetings is a mark of professionalism"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "講演、メンタリング、会議の時間を正確に守ることはプロフェッショナルの基本です"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "강연, 멘토링, 회의 시간을 정확하게 지키는 것은 전문성의 기본입니다"
          }
        }
      }
    },
    "onboarding_desc_2" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Avoid awkward moments from going overtime and keep your audience comfortable"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "時間超過による気まずい状況や聴衆の不快感を防ぎましょう"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "시간 초과로 인한 당황스러운 상황, 청중의 불편함을 방지하세요"
          }
        }
      }
    },
    "onboarding_desc_3" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Set as many pre-alerts as you want: 10 min, 5 min, 1 min before the end"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "終了10分前、5分前、1分前など、好きなだけ事前アラートを設定できます"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "종료 10분 전, 5분 전, 1분 전 등 원하는 만큼 예비 알림을 설정하세요"
          }
        }
      }
    },
    "onboarding_desc_4" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "After 00:00, it shows +01:23 so you know exactly how much overtime"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "00:00以降も+01:23のように表示され、正確な超過時間を確認できます"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
